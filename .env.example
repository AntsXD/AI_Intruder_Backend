APP_NAME=Intruder Detection Backend
ENV=dev
API_PREFIX=/api/v1
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=7
STREAM_TOKEN_MINUTES=10
DATABASE_URL=sqlite:///./intruder_demo.db
STORAGE_ROOT=./storage
WEBHOOK_API_KEY=CHANGE_ME_WEBHOOK_KEY
WEBHOOK_SIGNING_SECRET=
WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300
FIREBASE_CREDENTIALS_PATH=
FIREBASE_ALLOW_DEMO_TOKENS=false
FCM_ENABLED=false
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_APP_PASSWORD=
SMTP_FROM=
SMS_ENABLED=false
SMS_DEMO_TARGET=
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
AUTO_CREATE_TABLES=true
