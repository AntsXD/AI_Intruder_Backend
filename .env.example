APP_NAME=Intruder Detection Backend
ENV=dev
API_PREFIX=/api/v1
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7
STREAM_TOKEN_MINUTES=10
DATABASE_URL=sqlite:///./intruder_demo.db
STORAGE_ROOT=./storage
WEBHOOK_API_KEY=CHANGE_ME_WEBHOOK_KEY

FIREBASE_CREDENTIALS_PATH=
FCM_ENABLED=false
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_APP_PASSWORD=
SMTP_FROM=
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_FAKE_CHAT_ID=1234567890
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
AUTO_CREATE_TABLES=true

FIREBASE_TEST_EMAIL=
FIREBASE_TEST_PASSWORD=
FCM_TEST_TOKEN=
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_API_KEY=CHANGE_ME_AI_KEY
